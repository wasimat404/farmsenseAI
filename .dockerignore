# Local virtual environments and caches
venv/
__pycache__/
*.pyc
.pytest_cache/

# Node modules (will be reinstalled inside container)
**/node_modules/
**/build/

# Local env files (secrets shouldn't end up in images)
**/.env
**/.env.local

# Git
.git/
.gitignore

# IDE/editor
.vscode/
.idea/
*.swp

# OS junk
.DS_Store
Thumbs.db

# Docs/Notebooks not needed at runtime
*.ipynb
images/
README.md

# Backups created during development
**/*.backup
**/*.v2.backup
**/*.v3.backup
**/*.backup.*
